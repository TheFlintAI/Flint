{
  "name": "flint",
  "version": "0.9.109",
  "description": "Open-source desktop platform for multi-agent AI collaboration with local tools and workplace integration",
  "author": "example.com",
  "homepage": "https://github.com/flint/flint",
  "packageManager": "bun@1.3.10",
  "scripts": {
    "check": "bun ./scripts/check.mjs",
    "dev:check": "bun ./scripts/predev.mjs",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "bun run typecheck:web",
    "build:plugins": "bun ./scripts/build-plugins.mjs",
    "copy:resources": "bun ./scripts/copy-resources.mjs",
    "dev:web": "vite --host 127.0.0.1",
    "build:web": "vite build",
    "start": "vite preview --host 127.0.0.1",
    "dev": "bun run dev:check && tauri dev",
    "build": "bun run typecheck && tauri build --no-bundle",
    "build:win": "bun run build",
    "build:mac": "bun run build",
    "build:linux": "bun run build"
  },
  "dependencies": {
    "@git-diff-view/react": "^0.1.6",
    "@git-diff-view/shiki": "^0.1.6",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.18",
    "@tauri-apps/api": "^2.9.0",
    "@toon-format/toon": "^2.1.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-unicode11": "0.9.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "defuddle": "^0.19.0",
    "diff": "^9.0.0",
    "gpt-tokenizer": "^3.4.0",
    "i18next": "^25.8.6",
    "immer": "^11.1.3",
    "katex": "^0.16.45",
    "lucide-react": "^0.563.0",
    "mermaid": "^11.12.3",
    "motion": "^12.34.0",
    "nanoid": "^5.1.6",
    "partial-json": "^0.1.7",
    "radix-ui": "^1.4.3",
    "react-i18next": "^16.5.4",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.0",
    "recharts": "^3.9.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.9.0",
    "@types/diff": "^8.0.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.50.0",
    "vite": "^7.2.6"
  }
}
